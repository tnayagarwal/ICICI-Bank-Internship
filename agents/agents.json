{
  "version": "2.0",
  "last_updated": "2024-12-19",
  "schema_version": "advanced",
  "agents": {
    "attendance": {
      "name": "AttendanceAgent",
      "description": "Handles employee attendance operations including check-in, check-out, overtime calculations, attendance monitoring, and compliance tracking",
      "agent_type": "operational",
      "capabilities": [
        "checkin",
        "checkout", 
        "overtime_calculation",
        "attendance_monitoring",
        "compliance_tracking",
        "location_verification",
        "time_tracking",
        "schedule_validation"
      ],
      "functions": {
        "main_function": "attendance_agent_main",
        "process_function": "process_attendance",
        "module_path": "agents.attendance_agent"
      },
      "data_schemas": {
        "input_schema": {
          "emp_id": {
            "type": "string",
            "required": true,
            "validation": "^[0-9]{5}$",
            "description": "5-digit employee ID"
          },
          "action": {
            "type": "string", 
            "required": true,
            "enum": ["checkin", "checkout", "overtime", "status", "compliance"],
            "description": "Action to perform"
          },
          "timestamp": {
            "type": "string",
            "required": false,
            "format": "ISO8601",
            "description": "Optional timestamp override"
          }
        },
        "output_schema": {
          "status": {
            "type": "string",
            "enum": ["success", "error", "warning", "pending"],
            "description": "Operation status"
          },
          "message": {
            "type": "string",
            "description": "Human-readable result message"
          },
          "data": {
            "type": "object",
            "properties": {
              "attendance_id": {"type": "string"},
              "work_hours": {"type": "float"},
              "overtime_hours": {"type": "float"},
              "location_verified": {"type": "boolean"},
              "compliance_score": {"type": "float"}
            },
            "description": "Structured attendance data"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "processed_at": {"type": "string"},
              "agent_version": {"type": "string"},
              "confidence": {"type": "float"}
            }
          }
        }
      },
      "configuration": {
        "max_retries": 3,
        "timeout": 30,
        "priority": "HIGH",
        "requires_location": false,
        "async_capable": true,
        "stateful": false,
        "idempotent": true
      },
      "triggers": [
        "checkin", "check in", "check-in",
        "checkout", "check out", "check-out",
        "attendance", "present", "absent",
        "overtime", "extra hours", "work hours",
        "time tracking", "clock in", "clock out",
        "location", "office", "workplace"
      ],
      "inter_agent_compatibility": {
        "works_well_with": ["leave", "chatbot"],
        "conflicts_with": [],
        "data_dependencies": {
          "requires_from": {
            "chatbot": ["policy_info", "schedule_info"],
            "leave": ["leave_status", "approved_absences"]
          },
          "provides_to": {
            "leave": ["work_hours", "attendance_record"],
            "chatbot": ["attendance_status", "compliance_data"]
          }
        },
        "workflow_position": "primary",
        "can_initiate_workflows": true,
        "can_be_parallel": true
      },
      "dependencies": ["postgres_client"],
      "status": "active",
      "error_handling": {
        "retry_strategy": "exponential_backoff",
        "fallback_agent": "chatbot",
        "critical_errors": ["database_error"],
        "recoverable_errors": ["network_error"]
      }
    },
    "chatbot": {
      "name": "ChatbotAgent",
      "description": "Provides HR policy assistance, general knowledge, company information, and handles general conversational queries",
      "agent_type": "informational",
      "capabilities": [
        "hr_policy_assistance",
        "general_knowledge",
        "company_information",
        "conversation_handling",
        "document_search",
        "policy_interpretation",
        "question_answering",
        "context_gathering"
      ],
      "functions": {
        "main_function": "chatbot_agent_main",
        "process_function": "process_query",
        "module_path": "agents.chatbot_agent"
      },
      "data_schemas": {
        "input_schema": {
          "query": {
            "type": "string",
            "required": true,
            "min_length": 3,
            "max_length": 1000,
            "description": "User question or query"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "previous_queries": {"type": "array"},
              "employee_context": {"type": "object"},
              "workflow_context": {"type": "object"}
            },
            "description": "Additional context for better responses"
          },
          "response_format": {
            "type": "string",
            "enum": ["conversational", "structured", "policy_reference"],
            "default": "conversational"
          }
        },
        "output_schema": {
          "answer": {
            "type": "string",
            "description": "Generated response to the query"
          },
          "confidence": {
            "type": "float",
            "range": [0, 1],
            "description": "Confidence in the response accuracy"
          },
          "sources": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Information sources used"
          },
          "follow_up_questions": {
            "type": "array",
            "description": "Suggested follow-up questions"
          },
          "policy_references": {
            "type": "array",
            "description": "Relevant policy documents or sections"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "response_type": {"type": "string"},
              "processing_time": {"type": "float"},
              "context_used": {"type": "boolean"}
            }
          }
        }
      },
      "configuration": {
        "max_retries": 2,
        "timeout": 45,
        "priority": "MEDIUM",
        "requires_location": false,
        "async_capable": true,
        "stateful": true,
        "idempotent": false,
        "context_memory": true
      },
      "triggers": [
        "question", "help", "policy", "information",
        "what", "how", "when", "where", "why", "who",
        "explain", "tell me", "I want to know",
        "company", "rule", "procedure", "guideline"
      ],
      "inter_agent_compatibility": {
        "works_well_with": ["attendance", "leave", "complaint"],
        "conflicts_with": [],
        "data_dependencies": {
          "requires_from": {
            "attendance": ["attendance_patterns", "compliance_issues"],
            "leave": ["leave_policies", "approval_processes"],
            "complaint": ["common_issues", "resolution_patterns"]
          },
          "provides_to": {
            "attendance": ["policy_clarifications", "schedule_rules"],
            "leave": ["policy_interpretations", "process_guidance"],
            "complaint": ["policy_context", "escalation_procedures"]
          }
        },
        "workflow_position": "support",
        "can_initiate_workflows": false,
        "can_be_parallel": true,
        "coordination_role": "context_provider"
      },
      "dependencies": ["memory", "groq_client"],
      "status": "active",
      "error_handling": {
        "retry_strategy": "simple_retry",
        "fallback_response": "I apologize, but I'm unable to provide that information right now. Please try again or contact HR directly.",
        "critical_errors": ["llm_unavailable"],
        "recoverable_errors": ["context_loss", "memory_error"]
      }
    },
