  "multi_agent_workflows": {
    "comprehensive_employee_issue": {
      "description": "Handles complex employee issues requiring multiple agents",
      "agents": ["complaint", "attendance", "leave", "chatbot"],
      "workflow_type": "sequential_with_parallel",
      "priority": "HIGH",
      "execution_strategy": {
        "phase_1": {
          "agents": ["complaint"],
          "type": "sequential",
          "description": "Initial complaint processing and classification"
        },
        "phase_2": {
          "agents": ["attendance", "leave"],
          "type": "parallel",
          "condition": "if complaint involves attendance or leave issues",
          "description": "Gather context from relevant operational agents"
        },
        "phase_3": {
          "agents": ["chatbot"],
          "type": "sequential", 
          "description": "Policy interpretation and final response synthesis"
        }
      },
      "data_flow": {
        "complaint -> attendance": {
          "fields": ["emp_id", "issue_category", "time_period"],
          "transformation": "extract_attendance_relevant_data"
        },
        "complaint -> leave": {
          "fields": ["emp_id", "leave_related_issues", "dates_mentioned"],
          "transformation": "extract_leave_relevant_data"
        },
        "attendance -> chatbot": {
          "fields": ["compliance_issues", "policy_violations"],
          "transformation": "format_for_policy_lookup"
        },
        "leave -> chatbot": {
          "fields": ["policy_questions", "approval_issues"],
          "transformation": "format_for_policy_interpretation"
        },
        "all -> final_response": {
          "aggregation": "synthesize_comprehensive_response",
          "conflict_resolution": "priority_based_resolution"
        }
      },
      "conflict_resolution": {
        "strategy": "agent_priority",
        "priority_order": ["complaint", "leave", "attendance", "chatbot"],
        "resolution_rules": {
          "data_conflicts": "use_highest_priority_agent",
          "recommendation_conflicts": "escalate_to_human",
          "status_conflicts": "use_most_restrictive"
        }
      },
      "success_criteria": {
        "minimum_agents_success": 2,
        "required_agents": ["complaint"],
        "optional_agents": ["chatbot"]
      }
    },
    "attendance_leave_coordination": {
      "description": "Coordinates attendance tracking with leave management",
      "agents": ["attendance", "leave"],
      "workflow_type": "bidirectional",
      "priority": "MEDIUM",
      "execution_strategy": {
        "trigger_conditions": ["leave_request_with_attendance_impact", "attendance_discrepancy"],
        "coordination_type": "real_time_sync"
      },
      "data_flow": {
        "attendance -> leave": {
          "fields": ["current_attendance_status", "overtime_hours", "location_compliance"],
          "transformation": "attendance_to_leave_context"
        },
        "leave -> attendance": {
          "fields": ["approved_absences", "schedule_changes", "remote_work_approvals"],
          "transformation": "leave_to_attendance_context"
        }
      },
      "sync_strategy": {
        "frequency": "real_time",
        "conflict_detection": "automatic",
        "resolution": "policy_based"
      }
    },
    "policy_consultation_workflow": {
      "description": "Multi-agent policy consultation and interpretation",
      "agents": ["chatbot", "attendance", "leave", "complaint"],
      "workflow_type": "consultation",
      "priority": "LOW",
      "execution_strategy": {
        "primary_agent": "chatbot",
        "consultation_agents": ["attendance", "leave", "complaint"],
        "consultation_type": "expertise_based"
      },
      "data_flow": {
        "chatbot -> others": {
          "fields": ["policy_question", "context", "employee_situation"],
          "transformation": "policy_consultation_request"
        },
        "others -> chatbot": {
          "fields": ["domain_expertise", "precedents", "recommendations"],
          "transformation": "expertise_response"
        }
      },
      "aggregation_strategy": {
        "method": "weighted_consensus",
        "weights": {
          "chatbot": 0.4,
          "attendance": 0.25,
          "leave": 0.25,
          "complaint": 0.1
        }
      }
    }
  },
